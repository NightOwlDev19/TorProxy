# torrc.template
# ---------------
# Template for per-Tor-instance torrc files.
# Variables are substituted by TorController._build_torrc():
#   9054       → SOCKS5 listening port
#   9055     → Control port
#   C:\Users\Anwar jodi\Desktop\TorProxy\tor_data\instance-2         → Per-instance data directory (absolute path)
#   16:C272684B8ABC1EAF60C9ECF911BD748C363FAE9BB3A2C92C5F207C0EFE  → HashedControlPassword (from 'tor --hash-password')
#   notice        → notice | info | debug

SOCKSPort 9054
ControlPort 9055
DataDirectory C:\Users\Anwar jodi\Desktop\TorProxy\tor_data\instance-2
HashedControlPassword 16:C272684B8ABC1EAF60C9ECF911BD748C363FAE9BB3A2C92C5F207C0EFE
Log notice stdout
GeoIPFile C:\Users\Anwar jodi\Desktop\TorProxy\tor_bin\tor/geoip
GeoIPv6File C:\Users\Anwar jodi\Desktop\TorProxy\tor_bin\tor/geoip6

# ── Performance ───────────────────────────────────────────────────────────────
# Reduce circuit build timeout for faster failover
CircuitBuildTimeout 15
LearnCircuitBuildTimeout 0

# ── Safety / privacy ─────────────────────────────────────────────────────────
StrictNodes 0
ExitRelay 0
ClientOnly 1

# ── DNS through Tor ───────────────────────────────────────────────────────────
DNSPort 0

# ── Avoid entry/exit guard reuse ─────────────────────────────────────────────
# Each instance picks independent guards (minimises correlation)
UseEntryGuards 1
NumEntryGuards 3
