# TorProxy — Environment Variables
# Copy this file to .env and edit values as needed.

# ── Proxy listener ────────────────────────────────────────────────────────────
PROXY_HOST=0.0.0.0
PROXY_PORT=8080

# ── Tor instances ─────────────────────────────────────────────────────────────
# Number of parallel Tor circuits (each = one tor process)
NUM_CIRCUITS=3

# Base SOCKS5 port — instances get: base, base+2, base+4, …
SOCKS_BASE_PORT=9050

# Base control port — instances get: base+1, base+3, base+5, …
CONTROL_BASE_PORT=9051

# Path to tor binary (must be on PATH or provide full path)
# Windows example: TOR_BINARY=C:\Tor\tor.exe
TOR_BINARY=tor_bin\tor\tor.exe

# Directory where per-instance data is stored
# TOR_DATA_DIR=./tor_data

# ── Routing / retry ───────────────────────────────────────────────────────────
# PARALLEL_RACE=true   → race all circuits (fastest wins)
# PARALLEL_RACE=false  → sequential fallback
PARALLEL_RACE=true

# How many total attempts before giving up on a request
RETRY_LIMIT=5

# Per-request timeout in seconds
TIMEOUT_SEC=30

# ── Control auth ──────────────────────────────────────────────────────────────
# Password used to authenticate to Tor's control port
CONTROL_PASSWORD=torproxy_secret

# ── Server ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
STATS_ENDPOINT=true
