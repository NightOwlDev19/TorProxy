# =============================================================================
#  TorProxy — .gitignore
#  Python asyncio proxy server + React/Vite/TypeScript dashboard
# =============================================================================

# ── Tor runtime ───────────────────────────────────────────────────────────────
*.pid

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
.cache/

# mypy / pyright / ruff
.mypy_cache/
.ruff_cache/
pyrightconfig.json

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem
*.p12

# ── Node / frontend ───────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.lnk

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
